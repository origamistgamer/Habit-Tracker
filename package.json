{
	"name": "streakr",
	"version": "4.0.0",
	"description": "Streakr - Habit Tracker PWA",
	"private": true,
	"scripts": {
		"dev": "node server.js",
		"lint": "biome lint .",
		"format": "biome format .",
		"format:fix": "biome format . --write",
		"lint:fix": "biome check . --write",
		"knip": "knip",
		"audit": "npm audit --audit-level=high",
		"validate": "node -e \"const fs=require('fs');['manifest.json','package.json','biome.json'].forEach(f=>{const c=fs.readFileSync(f,'utf8');JSON.parse(c);console.log(f+': OK')})\""
	},
	"keywords": ["habits", "tracker", "pwa", "streaks"],
	"author": "origamistgamer",
	"license": "AGPL-3.0-or-later",
	"dependencies": {
		"express": "^4.21.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"knip": "^5.61.0"
	}
}